# .env 配置模板 — 复制为 .env 并填入你的真实密钥
# 注意：.env 文件绝不可以提交到 Git！

DEEPSEEK_API_KEY=your_deepseek_api_key_here
OPENAI_API_BASE=https://api.deepseek.com/v1

# LangSmith 链路追踪（可选）
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=miemie-multiagent-solver

# 双 Judge 交叉验证（可选，用于 benchmark --dual 模式）
# 使用独立模型（如 GPT-4）做 inter-rater reliability 校验
SECOND_JUDGE_API_KEY=your_second_judge_key_here
SECOND_JUDGE_BASE_URL=https://api.openai.com/v1
SECOND_JUDGE_MODEL=gpt-4
